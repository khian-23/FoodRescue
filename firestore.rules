rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasValidUserSchema(data) {
      return data.keys().hasOnly(['uid', 'name', 'email', 'role', 'userType']) &&
        data.uid is string &&
        data.name is string &&
        data.email is string &&
        data.role is string &&
        data.userType is string;
    }

    function hasValidListingSchema(data) {
      return data.keys().hasOnly([
        'id',
        'ownerUid',
        'ownerName',
        'title',
        'description',
        'quantity',
        'pickupLocation',
        'availableUntil',
        'status',
        'claimedByUid',
        'claimedByName'
      ]) &&
        data.id is string &&
        data.ownerUid is string &&
        data.ownerName is string &&
        data.title is string &&
        data.description is string &&
        data.quantity is string &&
        data.pickupLocation is string &&
        data.availableUntil is string &&
        data.status is string &&
        data.claimedByUid is string &&
        data.claimedByName is string;
    }

    function requesterUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && requesterUserDoc().data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() &&
        request.auth.uid == uid &&
        hasValidUserSchema(request.resource.data) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.role == 'user' &&
        (request.resource.data.userType == 'donor' ||
          request.resource.data.userType == 'rescuer');
      allow update: if isAdmin() &&
        hasValidUserSchema(request.resource.data) &&
        request.resource.data.uid == uid;
      allow delete: if isAdmin();
    }

    match /food_listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        hasValidListingSchema(request.resource.data) &&
        request.resource.data.id == listingId &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.status == 'open' &&
        request.resource.data.claimedByUid == '' &&
        request.resource.data.claimedByName == '';
      allow update: if hasValidListingSchema(request.resource.data) &&
        (
          isAdmin() ||
          (
            isSignedIn() &&
            (
              (
                request.resource.data.ownerUid == request.auth.uid &&
                resource.data.ownerUid == request.auth.uid &&
                request.resource.data.ownerUid == resource.data.ownerUid &&
                request.resource.data.ownerName == resource.data.ownerName
              ) ||
              (
                request.resource.data.claimedByUid == request.auth.uid &&
                request.resource.data.claimedByName is string &&
                resource.data.claimedByUid == '' &&
                resource.data.claimedByName == '' &&
                resource.data.status == 'open' &&
                request.resource.data.status == 'claimed' &&
                request.resource.data.ownerUid == resource.data.ownerUid &&
                request.resource.data.ownerName == resource.data.ownerName &&
                request.resource.data.title == resource.data.title &&
                request.resource.data.description == resource.data.description &&
                request.resource.data.quantity == resource.data.quantity &&
                request.resource.data.pickupLocation == resource.data.pickupLocation &&
                request.resource.data.availableUntil == resource.data.availableUntil
              )
            )
          )
        );
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }
  }
}
