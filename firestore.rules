rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasValidUserSchema(data) {
      return data.keys().hasOnly(['uid', 'name', 'email', 'role', 'userType']) &&
        data.uid is string &&
        data.name is string &&
        data.email is string &&
        data.role is string &&
        data.userType is string;
    }

    function hasValidListingSchema(data) {
      return data.keys().hasOnly([
        'id',
        'ownerUid',
        'ownerName',
        'title',
        'description',
        'quantity',
        'pickupLocation',
        'availableUntil',
        'status',
        'claimedByUid',
        'claimedByName'
      ]) &&
        data.id is string &&
        data.ownerUid is string &&
        data.ownerName is string &&
        data.title is string &&
        data.description is string &&
        data.quantity is string &&
        data.pickupLocation is string &&
        data.availableUntil is string &&
        data.status is string &&
        (data.claimedByUid is string || data.claimedByUid == '') &&
        (data.claimedByName is string || data.claimedByName == '');
    }

    function requesterUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && requesterUserDoc().data.role == 'admin';
    }

    function isAvailableForClaim(data) {
      return data.status == 'open' &&
        (data.claimedByUid == '' || !('claimedByUid' in data)) &&
        (data.claimedByName == '' || !('claimedByName' in data));
    }

    // =========================
    // USERS
    // =========================
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      allow create: if isSignedIn() &&
        request.auth.uid == uid &&
        hasValidUserSchema(request.resource.data) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.role == 'user' &&
        (request.resource.data.userType == 'donor' ||
         request.resource.data.userType == 'rescuer');

      allow update: if isAdmin() &&
        hasValidUserSchema(request.resource.data) &&
        request.resource.data.uid == uid;

      allow delete: if isAdmin();
    }

    // =========================
    // FOOD LISTINGS
    // =========================
    match /food_listings/{listingId} {

      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        hasValidListingSchema(request.resource.data) &&
        request.resource.data.id == listingId &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.status == 'open' &&
        request.resource.data.claimedByUid == '' &&
        request.resource.data.claimedByName == '';

      allow update: if isSignedIn() && (

        isAdmin() ||

        // OWNER can only update NON-critical fields
        (
          resource.data.ownerUid == request.auth.uid &&
          request.resource.data.ownerUid == resource.data.ownerUid &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.claimedByUid == resource.data.claimedByUid &&
          request.resource.data.claimedByName == resource.data.claimedByName
        ) ||

        // CLAIM FLOW (STRICT)
        (
          isAvailableForClaim(resource.data) &&
          request.resource.data.status == 'claimed' &&
          request.resource.data.claimedByUid == request.auth.uid &&
          request.resource.data.claimedByName is string &&
          request.resource.data.claimedByName != ''
        )
      );

      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }
  }
}